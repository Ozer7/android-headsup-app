<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="HeadsUp!" />

    <include layout="@layout/content_main" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab"
        android:layout_width="@dimen/FABWidthMain"
        android:layout_height="@dimen/FABHeightMain"
        android:layout_gravity="bottom|center"
        android:layout_margin="@dimen/fab_margin"
        android:text="@string/FABText"
        android:textColor="@color/black"
        android:textSize="@dimen/MainFABTextSize"
        app:backgroundTint="@color/blue"
        app:icon="@drawable/clipart4779006"
        app:iconSize="@dimen/MainFABIconSize"
        app:iconPadding="@dimen/MainFABIconPadding"
        app:iconTint="@color/black" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>