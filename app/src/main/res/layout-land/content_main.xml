<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/resultText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center|top"
        android:text="@string/ResultOriginalText"
        android:textColor="@color/ResultCoin"
        android:textSize="@dimen/ResultTextSize"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/headsCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:text="@string/HeadsCounterOriginal"
        android:textColor="@color/Coins"
        android:textSize="@dimen/CoinsResultTextSize"
        app:layout_constraintStart_toStartOf="@+id/tailsCountText"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tailsCountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="120dp"
        android:text="@string/TailsCounterOriginal"
        android:textColor="@color/Coins"
        android:textSize="@dimen/CoinsResultTextSize"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headsCountText" />

</androidx.constraintlayout.widget.ConstraintLayout>
